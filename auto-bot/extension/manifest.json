{
  "manifest_version": 3,
  "name": "MarketFill",
  "description": "MarketFill pre-fills Facebook Marketplace vehicle listings from dealer inventory pages. Open a dealer's vehicle page, let MarketFill read the details and photos, review, and post in under a minute.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/DAS_1.0_16x16.png",
    "48": "icons/DAS_1.0_48x48.png",
    "128": "icons/DAS_1.0_128x128.png"
  },
  "action": {
    "default_title": "MarketFill",
    "default_icon": {
      "16": "icons/DAS_1.0_16x16.png",
      "48": "icons/DAS_1.0_48x48.png",
      "128": "icons/DAS_1.0_128x128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/create/vehicle*"
      ],
      "js": ["facebook_fill.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://www.facebook.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["facebook_fill.js"],
      "matches": ["https://www.facebook.com/*"]
    }
  ]
}
